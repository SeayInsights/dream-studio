/*
 * YARA Rules — {{ client.name }}
 * Generated by dream-studio:binary-scan setup
 * Target: {{ target.name }}
 * Platform: {{ target.platform | default('unknown') }}
 */

// ── Hardcoded Credentials ───────────────────────────────────────────────────

rule HardcodedPassword
{
    meta:
        description = "Detects hardcoded password strings in binary"
        severity = "high"
        rule_id = "BIN-yar-hardcoded-password"
        cwe = "CWE-798"
        owasp = "A07:2021"

    strings:
        $pwd1 = "password" ascii nocase
        $pwd2 = "passwd" ascii nocase
        $pwd3 = "pass=" ascii nocase
        $pwd4 = "pwd=" ascii nocase
        $secret1 = "secret" ascii nocase
        $secret2 = "api_key" ascii nocase
        $secret3 = "apikey" ascii nocase
        $secret4 = "access_token" ascii nocase
        $secret5 = "private_key" ascii nocase

    condition:
        any of them
}

rule HardcodedAWSKey
{
    meta:
        description = "Detects AWS access key patterns"
        severity = "critical"
        rule_id = "BIN-yar-aws-key"
        cwe = "CWE-798"
        owasp = "A02:2021"

    strings:
        $aws_access = /AKIA[0-9A-Z]{16}/
        $aws_secret = /[0-9a-zA-Z\/+]{40}/

    condition:
        $aws_access or ($aws_secret and $aws_access)
}

// ── Embedded URLs and IPs ───────────────────────────────────────────────────

rule EmbeddedInternalURL
{
    meta:
        description = "Detects hardcoded internal URLs"
        severity = "medium"
        rule_id = "BIN-yar-internal-url"
        cwe = "CWE-200"

    strings:
        $internal1 = "http://localhost" ascii nocase
        $internal2 = "http://127.0.0.1" ascii nocase
        $internal3 = "http://10." ascii
        $internal4 = "http://172.16." ascii
        $internal5 = "http://192.168." ascii
        $internal6 = "http://169.254.169.254" ascii

    condition:
        any of them
}

rule EmbeddedDatabaseConnectionString
{
    meta:
        description = "Detects database connection strings"
        severity = "high"
        rule_id = "BIN-yar-db-conn"
        cwe = "CWE-798"
        owasp = "A07:2021"

    strings:
        $pg = "postgresql://" ascii nocase
        $mysql = "mysql://" ascii nocase
        $mssql = "mssql://" ascii nocase
        $sqlite = "sqlite:///" ascii
        $mongo = "mongodb://" ascii nocase
        $redis = "redis://" ascii nocase
        $connstr = "Server=" ascii nocase

    condition:
        any of them
}

// ── Client-Specific Data Patterns ───────────────────────────────────────────

{% if client.data.pii_patterns is defined and client.data.pii_patterns %}
rule ClientPIIPatterns
{
    meta:
        description = "Detects PII patterns defined in client profile"
        severity = "high"
        rule_id = "BIN-yar-client-pii"
        cwe = "CWE-359"
        owasp = "A01:2021"

    strings:
{% for pattern in client.data.pii_patterns %}
        $pii_{{ loop.index }} = /{{ pattern }}/ ascii
{% endfor %}

    condition:
        any of them
}
{% endif %}

{% if client.data.critical is defined and client.data.critical %}
rule ClientCriticalDataTerms
{
    meta:
        description = "Detects critical data classification terms from client profile"
        severity = "medium"
        rule_id = "BIN-yar-critical-terms"
        cwe = "CWE-200"

    strings:
{% for term in client.data.critical %}
        $critical_{{ loop.index }} = "{{ term }}" ascii nocase
{% endfor %}

    condition:
        any of them
}
{% endif %}

// ── Known Packer / Obfuscation Signatures ───────────────────────────────────

rule UPXPacked
{
    meta:
        description = "Binary is UPX packed — may indicate evasion"
        severity = "low"
        rule_id = "BIN-yar-upx-packed"
        cwe = "CWE-506"

    strings:
        $upx0 = "UPX0" ascii
        $upx1 = "UPX1" ascii
        $upx2 = "UPX!" ascii

    condition:
        2 of them
}

rule SuspiciousEntropy
{
    meta:
        description = "High entropy section detected — possible encryption or packing"
        severity = "low"
        rule_id = "BIN-yar-high-entropy"
        cwe = "CWE-506"

    strings:
        $packed = { 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 00 }

    condition:
        #packed > 100
}
