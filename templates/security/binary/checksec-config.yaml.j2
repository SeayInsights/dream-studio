# checksec configuration — {{ client.name }}
# Generated by dream-studio:binary-scan setup
# Target: {{ target.name }}
# Platform: {{ target.platform | default('unknown') }}

target:
  name: "{{ target.name }}"
  platform: "{{ target.platform | default('unknown') }}"

{% if target.platform == 'linux' or target.platform is not defined %}
# Linux / ELF hardening checks
linux_checks:
  nx:
    description: "Non-executable stack (NX/DEP)"
    severity_on_fail: high
    rule_id: "BIN-chk-nx"
    cwe: "CWE-119"
  pie:
    description: "Position Independent Executable (ASLR support)"
    severity_on_fail: high
    rule_id: "BIN-chk-pie"
    cwe: "CWE-119"
  relro:
    description: "Relocation Read-Only (full RELRO preferred)"
    severity_on_fail: medium
    rule_id: "BIN-chk-relro"
    cwe: "CWE-119"
    expected: "full"
  canary:
    description: "Stack canaries (stack smashing protection)"
    severity_on_fail: high
    rule_id: "BIN-chk-canary"
    cwe: "CWE-121"
  fortify:
    description: "FORTIFY_SOURCE (bounds checking on libc functions)"
    severity_on_fail: medium
    rule_id: "BIN-chk-fortify"
    cwe: "CWE-120"
  runpath:
    description: "RUNPATH/RPATH not set to writable directories"
    severity_on_fail: medium
    rule_id: "BIN-chk-runpath"
    cwe: "CWE-426"
{% endif %}

{% if target.platform == 'windows' %}
# Windows / PE hardening checks
windows_checks:
  dep:
    description: "Data Execution Prevention (DEP/NX)"
    severity_on_fail: high
    rule_id: "BIN-chk-dep"
    cwe: "CWE-119"
  aslr:
    description: "Address Space Layout Randomization"
    severity_on_fail: high
    rule_id: "BIN-chk-aslr"
    cwe: "CWE-119"
  cfg:
    description: "Control Flow Guard"
    severity_on_fail: medium
    rule_id: "BIN-chk-cfg"
    cwe: "CWE-119"
  safeseh:
    description: "Safe Structured Exception Handling"
    severity_on_fail: medium
    rule_id: "BIN-chk-safeseh"
    cwe: "CWE-119"
  authenticode:
    description: "Authenticode signature present and valid"
    severity_on_fail: high
    rule_id: "BIN-chk-authenticode"
    cwe: "CWE-345"
  high_entropy_va:
    description: "High Entropy Virtual Address (64-bit ASLR)"
    severity_on_fail: low
    rule_id: "BIN-chk-heva"
    cwe: "CWE-119"
{% endif %}

{% if target.platform == 'macos' %}
# macOS / Mach-O hardening checks
macos_checks:
  pie:
    description: "Position Independent Executable"
    severity_on_fail: high
    rule_id: "BIN-chk-pie"
    cwe: "CWE-119"
  stack_canary:
    description: "Stack canaries enabled"
    severity_on_fail: high
    rule_id: "BIN-chk-canary"
    cwe: "CWE-121"
  arc:
    description: "Automatic Reference Counting"
    severity_on_fail: low
    rule_id: "BIN-chk-arc"
    cwe: "CWE-416"
  code_sign:
    description: "Code signature present and valid"
    severity_on_fail: high
    rule_id: "BIN-chk-codesign"
    cwe: "CWE-345"
  hardened_runtime:
    description: "Hardened runtime enabled"
    severity_on_fail: medium
    rule_id: "BIN-chk-hardened"
    cwe: "CWE-693"
{% endif %}
