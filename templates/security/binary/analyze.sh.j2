#!/usr/bin/env bash
# Binary Analysis Script — {{ client.name }}
# Generated by dream-studio:binary-scan setup
# Target: {{ target.name }}
# Platform: {{ target.platform | default('unknown') }}

set -euo pipefail

BINARY_PATH="${1:?Usage: analyze.sh <binary-path>}"
OUTPUT_DIR="${2:-$(pwd)}"
TARGET_NAME="{{ target.name }}"

echo "=== Binary Analysis: $TARGET_NAME ==="
echo "Binary: $BINARY_PATH"
echo "Output: $OUTPUT_DIR"

mkdir -p "$OUTPUT_DIR"

# ── SHA256 Hash ──────────────────────────────────────────────────────────────
echo ""
echo "--- Computing SHA256 hash ---"
HASH=$(sha256sum "$BINARY_PATH" | awk '{print $1}')
echo "SHA256: $HASH"
echo "{\"binary_hash\": \"$HASH\", \"binary_name\": \"$(basename "$BINARY_PATH")\"}" > "$OUTPUT_DIR/hash.json"

# ── checksec ─────────────────────────────────────────────────────────────────
echo ""
echo "--- Running checksec ---"
{% if target.platform == 'windows' %}
if command -v winchecksec &> /dev/null; then
    winchecksec "$BINARY_PATH" > "$OUTPUT_DIR/checksec.json" 2>&1 || true
    echo "checksec output saved to $OUTPUT_DIR/checksec.json"
elif command -v wsl &> /dev/null; then
    WSL_PATH=$(wslpath "$BINARY_PATH" 2>/dev/null || echo "$BINARY_PATH")
    wsl checksec --output=json --file="$WSL_PATH" > "$OUTPUT_DIR/checksec.json" 2>&1 || true
    echo "checksec output saved (via WSL) to $OUTPUT_DIR/checksec.json"
else
    echo '{"error": "Neither winchecksec nor WSL checksec available"}' > "$OUTPUT_DIR/checksec.json"
    echo "WARNING: Install winchecksec or enable WSL with checksec"
fi
{% else %}
if command -v checksec &> /dev/null; then
    checksec --output=json --file="$BINARY_PATH" > "$OUTPUT_DIR/checksec.json" 2>&1 || true
    echo "checksec output saved to $OUTPUT_DIR/checksec.json"
else
    echo '{"error": "checksec not installed"}' > "$OUTPUT_DIR/checksec.json"
    echo "WARNING: Install checksec (apt install checksec / brew install checksec)"
fi
{% endif %}

# ── YARA ─────────────────────────────────────────────────────────────────────
echo ""
echo "--- Running YARA rules ---"
YARA_RULES="{{ yara_rules_path | default('yara-rules.yar') }}"
if command -v yara &> /dev/null && [ -f "$YARA_RULES" ]; then
    yara -j "$YARA_RULES" "$BINARY_PATH" > "$OUTPUT_DIR/yara-matches.json" 2>&1 || true
    echo "YARA output saved to $OUTPUT_DIR/yara-matches.json"
else
    echo '{"matches": []}' > "$OUTPUT_DIR/yara-matches.json"
    if ! command -v yara &> /dev/null; then
        echo "WARNING: YARA not installed (apt install yara / brew install yara)"
    fi
    if [ ! -f "$YARA_RULES" ]; then
        echo "WARNING: YARA rules file not found at $YARA_RULES"
    fi
fi

# ── Strings Analysis ────────────────────────────────────────────────────────
echo ""
echo "--- Running strings analysis ---"
if command -v strings &> /dev/null; then
    strings "$BINARY_PATH" | grep -iE '(https?://|[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+|password|passwd|secret|api.key|token|private.key|BEGIN .* KEY)' \
        > "$OUTPUT_DIR/strings-raw.txt" 2>/dev/null || true
    STRINGS_COUNT=$(wc -l < "$OUTPUT_DIR/strings-raw.txt" 2>/dev/null || echo 0)
    echo "Found $STRINGS_COUNT suspicious strings"

    # Convert to JSON
    python3 -c "
import json, sys
findings = []
with open('$OUTPUT_DIR/strings-raw.txt') as f:
    for i, line in enumerate(f, 1):
        line = line.strip()
        if line:
            findings.append({'index': i, 'value': line[:200]})
json.dump({'findings': findings[:100]}, sys.stdout, indent=2)
" > "$OUTPUT_DIR/strings-findings.json" 2>/dev/null || echo '{"findings": []}' > "$OUTPUT_DIR/strings-findings.json"
else
    echo '{"findings": []}' > "$OUTPUT_DIR/strings-findings.json"
    echo "WARNING: strings command not available"
fi

# ── File metadata ────────────────────────────────────────────────────────────
echo ""
echo "--- Collecting file metadata ---"
FILE_SIZE=$(stat -c%s "$BINARY_PATH" 2>/dev/null || stat -f%z "$BINARY_PATH" 2>/dev/null || echo 0)
FILE_TYPE=$(file -b "$BINARY_PATH" 2>/dev/null || echo "unknown")
echo "{\"file_size\": $FILE_SIZE, \"file_type\": \"$FILE_TYPE\"}" > "$OUTPUT_DIR/metadata.json"

echo ""
echo "=== Analysis Complete ==="
echo "Results written to: $OUTPUT_DIR"
ls -la "$OUTPUT_DIR"
