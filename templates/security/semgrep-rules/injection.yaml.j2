# Semgrep rules — Injection
# Generated for client: {{ client.name }}
# Template: injection.yaml.j2
# Coverage: SQL string concatenation, missing parameterized queries,
#           command injection, XSS, template injection
rules:

  # INJ-001: SQL string concatenation via f-string (Python)
  - id: {{ client.name | lower }}-inj-001-sql-fstring-concat
    pattern-either:
      - pattern: |
          $DB.execute(f"...SELECT...{$VAR}...")
      - pattern: |
          $DB.execute(f"...INSERT...{$VAR}...")
      - pattern: |
          $DB.execute(f"...UPDATE...{$VAR}...")
      - pattern: |
          $DB.execute(f"...DELETE...{$VAR}...")
      - pattern: |
          $DB.execute(f"...WHERE...{$VAR}...")
      - pattern: |
          $QUERY = f"SELECT ...{$VAR}..."
          ...
          $DB.execute($QUERY)
      - pattern: |
          $QUERY = f"INSERT ...{$VAR}..."
          ...
          $DB.execute($QUERY)
      - pattern: |
          $QUERY = f"UPDATE ...{$VAR}..."
          ...
          $DB.execute($QUERY)
      - pattern: |
          $QUERY = f"DELETE ...{$VAR}..."
          ...
          $DB.execute($QUERY)
      - pattern: |
          $QUERY = "SELECT ..." + $VAR + "..."
          ...
          $DB.execute($QUERY)
      - pattern: |
          $QUERY = "INSERT ..." + $VAR + "..."
          ...
          $DB.execute($QUERY)
    message: >
      SQL query built using f-string or string concatenation — SQL injection risk.
      User-controlled data must never be interpolated directly into SQL.
      Use parameterized queries: cursor.execute("SELECT ... WHERE id = %s", (value,))
      This is especially critical for {{ client.name }} data:
      {{ client.data.critical | join(', ') }}.
    severity: ERROR
    languages: [python]
    metadata:
      owasp: "A03:2021 - Injection"
      cwe: "CWE-89: Improper Neutralization of Special Elements used in an SQL Command"
      category: security
      confidence: HIGH
      client: {{ client.name }}

  # INJ-002: SQL string concatenation (JavaScript/TypeScript)
  - id: {{ client.name | lower }}-inj-002-sql-concat-js
    pattern-either:
      - pattern: |
          $DB.query(`SELECT ...${$VAR}...`)
      - pattern: |
          $DB.query(`INSERT ...${$VAR}...`)
      - pattern: |
          $DB.query(`UPDATE ...${$VAR}...`)
      - pattern: |
          $DB.query(`DELETE ...${$VAR}...`)
      - pattern: |
          $DB.query(`...WHERE ...${$VAR}...`)
      - pattern: |
          $DB.raw(`SELECT ...${$VAR}...`)
      - pattern: |
          $DB.raw(`INSERT ...${$VAR}...`)
      - pattern: |
          const $Q = "SELECT ..." + $VAR + "...";
          ...
          $DB.query($Q)
    message: >
      SQL query built using template literal or string concatenation in JavaScript —
      SQL injection risk. Use parameterized queries or an ORM query builder.
      Example: db.query("SELECT * FROM t WHERE id = ?", [value])
    severity: ERROR
    languages: [javascript, typescript]
    metadata:
      owasp: "A03:2021 - Injection"
      cwe: "CWE-89: Improper Neutralization of Special Elements used in an SQL Command"
      category: security
      confidence: HIGH
      client: {{ client.name }}

  # INJ-003: Raw SQL execution without parameterization (Python ORM)
  - id: {{ client.name | lower }}-inj-003-raw-sql-no-params
    pattern-either:
      - pattern: |
          $MODEL.objects.raw($QUERY)
      - pattern: |
          $MODEL.objects.raw($QUERY, [])
      - pattern: |
          connection.execute($QUERY)
      - pattern: |
          $CURSOR.execute($QUERY)
      - pattern: |
          db.session.execute($QUERY)
      - pattern: |
          text($QUERY)
    pattern-not-either:
      - pattern: |
          $CURSOR.execute($QUERY, $PARAMS)
      - pattern: |
          $CURSOR.execute($QUERY, ($PARAM,))
      - pattern: |
          $MODEL.objects.raw($QUERY, $PARAMS)
      - pattern: |
          db.session.execute(text($Q), $PARAMS)
    message: >
      Raw SQL executed without parameterization. Single-argument execute() calls
      are injection-prone if the query string is dynamic.
      Always pass parameters as the second argument:
        cursor.execute(sql, (param1, param2))
        db.session.execute(text(sql), {"param": value})
    severity: ERROR
    languages: [python]
    metadata:
      owasp: "A03:2021 - Injection"
      cwe: "CWE-89: Improper Neutralization of Special Elements used in an SQL Command"
      category: security
      confidence: MEDIUM
      client: {{ client.name }}

  # INJ-004: Command injection via os.system / subprocess with shell=True (Python)
  - id: {{ client.name | lower }}-inj-004-command-injection-python
    pattern-either:
      - pattern: |
          os.system($CMD)
      - pattern: |
          os.system(f"...{$VAR}...")
      - pattern: |
          os.popen($CMD)
      - pattern: |
          subprocess.call($CMD, shell=True)
      - pattern: |
          subprocess.run($CMD, shell=True)
      - pattern: |
          subprocess.Popen($CMD, shell=True)
      - pattern: |
          subprocess.check_output($CMD, shell=True)
      - pattern: |
          subprocess.call(f"...{$VAR}...", shell=True)
      - pattern: |
          subprocess.run(f"...{$VAR}...", shell=True)
      - pattern: |
          subprocess.Popen(f"...{$VAR}...", shell=True)
    message: >
      Command injection risk: shell=True with dynamic input or os.system() with
      user-controlled data allows arbitrary command execution.
      Use subprocess with a list argument (no shell=True):
        subprocess.run(["cmd", arg1, arg2], shell=False)
      Never pass user input directly to shell commands.
    severity: ERROR
    languages: [python]
    metadata:
      owasp: "A03:2021 - Injection"
      cwe: "CWE-78: Improper Neutralization of Special Elements used in an OS Command"
      category: security
      confidence: HIGH
      client: {{ client.name }}

  # INJ-005: Command injection via exec / child_process (JavaScript/TypeScript)
  - id: {{ client.name | lower }}-inj-005-command-injection-js
    pattern-either:
      - pattern: |
          exec($CMD)
      - pattern: |
          exec(`...${$VAR}...`)
      - pattern: |
          execSync(`...${$VAR}...`)
      - pattern: |
          spawn($CMD, { shell: true })
      - pattern: |
          spawnSync($CMD, { shell: true })
      - pattern: |
          execFile(`...${$VAR}...`)
      - pattern: |
          eval($VAR)
      - pattern: |
          new Function($VAR)
    message: >
      Command or code injection risk detected in JavaScript/TypeScript.
      Dynamic values must not be interpolated into shell commands or eval().
      Use execFile() with an explicit argument array instead of exec() with template literals.
      Never use eval() or new Function() with external input.
    severity: ERROR
    languages: [javascript, typescript]
    metadata:
      owasp: "A03:2021 - Injection"
      cwe: "CWE-78: Improper Neutralization of Special Elements used in an OS Command"
      category: security
      confidence: HIGH
      client: {{ client.name }}

  # INJ-006: XSS via direct DOM manipulation (JavaScript/TypeScript)
  - id: {{ client.name | lower }}-inj-006-xss-dom
    pattern-either:
      - pattern: |
          $EL.innerHTML = $VAR
      - pattern: |
          $EL.innerHTML += $VAR
      - pattern: |
          $EL.outerHTML = $VAR
      - pattern: |
          document.write($VAR)
      - pattern: |
          document.writeln($VAR)
      - pattern: |
          $EL.insertAdjacentHTML($POS, $VAR)
    message: >
      Cross-site scripting (XSS) risk: direct assignment to innerHTML/outerHTML or
      use of document.write() with dynamic content allows script injection.
      Use textContent/innerText for plain text, or DOMPurify.sanitize() before
      assigning HTML. Never write unescaped user input to the DOM.
    severity: ERROR
    languages: [javascript, typescript]
    metadata:
      owasp: "A03:2021 - Injection"
      cwe: "CWE-79: Improper Neutralization of Input During Web Page Generation"
      category: security
      confidence: HIGH
      client: {{ client.name }}

  # INJ-007: XSS via dangerouslySetInnerHTML (React/TypeScript)
  - id: {{ client.name | lower }}-inj-007-xss-react-dangerous
    pattern-either:
      - pattern: |
          <$COMP dangerouslySetInnerHTML={{ "{{" }}{ __html: $VAR }{{ "}}" }} />
      - pattern: |
          <$COMP dangerouslySetInnerHTML={{ "{{" }}{ __html: $VAR + $VAR2 }{{ "}}" }} />
      - pattern: |
          dangerouslySetInnerHTML={{ "{{" }}{ __html: $VAR }{{ "}}" }}
    message: >
      React dangerouslySetInnerHTML used with a dynamic value — XSS risk.
      Always sanitize HTML before passing to dangerouslySetInnerHTML:
        import DOMPurify from 'dompurify';
        <div dangerouslySetInnerHTML={{ "{{" }}{ __html: DOMPurify.sanitize(content) }{{ "}}" }} />
    severity: ERROR
    languages: [javascript, typescript]
    metadata:
      owasp: "A03:2021 - Injection"
      cwe: "CWE-79: Improper Neutralization of Input During Web Page Generation"
      category: security
      confidence: HIGH
      client: {{ client.name }}

  # INJ-008: Server-side template injection (Python)
  - id: {{ client.name | lower }}-inj-008-template-injection-python
    pattern-either:
      - pattern: |
          Template($VAR).render(...)
      - pattern: |
          Template($VAR).render(**$KWARGS)
      - pattern: |
          jinja2.Template($VAR).render(...)
      - pattern: |
          render_template_string($VAR)
      - pattern: |
          render_template_string($VAR, **$KWARGS)
      - pattern: |
          $ENV.from_string($VAR).render(...)
    pattern-not-either:
      - pattern: |
          Template("...").render(...)
      - pattern: |
          render_template_string("...", ...)
    message: >
      Server-side template injection (SSTI) risk: Jinja2 Template() or
      render_template_string() called with a dynamic/user-supplied string.
      Attackers can execute arbitrary Python via {{ "{{" }} config.__class__... {{ "}}" }}.
      Always use static template strings loaded from files, not user input.
    severity: ERROR
    languages: [python]
    metadata:
      owasp: "A03:2021 - Injection"
      cwe: "CWE-94: Improper Control of Generation of Code"
      category: security
      confidence: HIGH
      client: {{ client.name }}
