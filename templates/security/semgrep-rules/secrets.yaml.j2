rules:

  # Rule 1: Hardcoded passwords and secrets in variable assignments
  - id: {{ client.name | lower }}-sec-001
    pattern-either:
      - pattern: |
          $VAR = "..."
      - pattern: |
          $VAR = '...'
    pattern-inside:
      patterns:
        - pattern-regex: '(?i)(password|passwd|secret|api_key|token|auth_token|access_token|private_key)\s*='
    message: >
      Hardcoded credential detected in variable assignment. Variable name suggests
      a secret value is being stored in source code. Use environment variables or
      a secrets manager instead. Found in {{ client.name }} codebase — secrets
      must not be committed.
    severity: ERROR
    languages:
      - python
      - javascript
      - typescript
    metadata:
      owasp: "A07:2021 - Identification and Authentication Failures"
      cwe: "CWE-798: Use of Hard-coded Credentials"
      category: security
      confidence: MEDIUM
      client: {{ client.name }}
      rule-group: secrets

  # Rule 2: Hardcoded passwords in Python keyword arguments
  - id: {{ client.name | lower }}-sec-002
    pattern-either:
      - pattern: |
          password="..."
      - pattern: |
          password='...'
      - pattern: |
          passwd="..."
      - pattern: |
          passwd='...'
      - pattern: |
          secret="..."
      - pattern: |
          secret='...'
      - pattern: |
          api_key="..."
      - pattern: |
          api_key='...'
    message: >
      Hardcoded credential passed as keyword argument. This will be visible in
      source control history. Use os.environ or a secrets manager. Found in
      {{ client.name }} codebase.
    severity: ERROR
    languages:
      - python
    metadata:
      owasp: "A07:2021 - Identification and Authentication Failures"
      cwe: "CWE-798: Use of Hard-coded Credentials"
      category: security
      confidence: HIGH
      client: {{ client.name }}
      rule-group: secrets

  # Rule 3: API keys matching common key formats in string literals
  - id: {{ client.name | lower }}-sec-003
    pattern-either:
      - pattern-regex: '(?i)(AKIA|AGPA|AIPA|ANPA|ANVA|AROA)[A-Z0-9]{16}'
      - pattern-regex: '(?i)AIza[0-9A-Za-z\-_]{35}'
      - pattern-regex: '(?i)[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}'
      - pattern-regex: '(?i)(sk|pk)_(live|test)_[0-9a-zA-Z]{24,}'
      - pattern-regex: '(?i)ghp_[0-9a-zA-Z]{36}'
      - pattern-regex: '(?i)xoxb-[0-9]{11}-[0-9]{11}-[0-9a-zA-Z]{24}'
      - pattern-regex: '(?i)[0-9a-zA-Z+/]{40,}={0,2}'
    message: >
      Potential API key or token detected matching a known credential format
      (AWS, GCP, Stripe, GitHub, Slack, or generic base64 secret). Verify this
      is not a real credential. {{ client.name }} credentials must be stored in
      approved secrets management, never in source code.
    severity: ERROR
    languages:
      - python
      - javascript
      - typescript
    metadata:
      owasp: "A07:2021 - Identification and Authentication Failures"
      cwe: "CWE-312: Cleartext Storage of Sensitive Information"
      category: security
      confidence: LOW
      client: {{ client.name }}
      rule-group: secrets

  # Rule 4: Database connection strings with embedded credentials
  - id: {{ client.name | lower }}-sec-004
    pattern-either:
      - pattern-regex: 'postgresql://[^:]+:[^@]+@'
      - pattern-regex: 'mysql://[^:]+:[^@]+@'
      - pattern-regex: 'mysql\+pymysql://[^:]+:[^@]+@'
      - pattern-regex: 'mssql\+pyodbc://[^:]+:[^@]+@'
      - pattern-regex: 'mongodb://[^:]+:[^@]+@'
      - pattern-regex: 'redis://:([^@]+)@'
      - pattern-regex: 'amqp://[^:]+:[^@]+@'
      - pattern-regex: 'jdbc:[a-z]+://[^;]+;[Pp]assword=[^;]+'
    message: >
      Database connection string with embedded credentials detected. Connection
      strings containing username:password should never be hardcoded. Use
      environment variables (DATABASE_URL) and ensure the connection string is
      loaded at runtime, not stored in source. Critical for {{ client.name }}
      data stores protecting: {{ client.data.critical | join(', ') }}.
    severity: ERROR
    languages:
      - python
      - javascript
      - typescript
    metadata:
      owasp: "A07:2021 - Identification and Authentication Failures"
      cwe: "CWE-312: Cleartext Storage of Sensitive Information"
      category: security
      confidence: HIGH
      client: {{ client.name }}
      rule-group: secrets

  # Rule 5: Private key material in source files
  - id: {{ client.name | lower }}-sec-005
    pattern-either:
      - pattern-regex: '-----BEGIN RSA PRIVATE KEY-----'
      - pattern-regex: '-----BEGIN EC PRIVATE KEY-----'
      - pattern-regex: '-----BEGIN OPENSSH PRIVATE KEY-----'
      - pattern-regex: '-----BEGIN DSA PRIVATE KEY-----'
      - pattern-regex: '-----BEGIN PGP PRIVATE KEY BLOCK-----'
      - pattern-regex: '-----BEGIN PRIVATE KEY-----'
    message: >
      Private key material found in source file. Private keys must never be
      committed to source control. Rotate this key immediately and store it in
      a secrets manager or environment variable. This is a critical finding for
      {{ client.name }}.
    severity: ERROR
    languages:
      - python
      - javascript
      - typescript
      - generic
    metadata:
      owasp: "A02:2021 - Cryptographic Failures"
      cwe: "CWE-321: Use of Hard-coded Cryptographic Key"
      category: security
      confidence: HIGH
      client: {{ client.name }}
      rule-group: secrets

  # Rule 6: os.getenv with hardcoded fallback defaults (secret leakage path)
  - id: {{ client.name | lower }}-sec-006
    pattern-either:
      - pattern: |
          os.getenv($KEY, $DEFAULT)
      - pattern: |
          os.environ.get($KEY, $DEFAULT)
    pattern-inside:
      patterns:
        - pattern-not: |
            os.getenv($KEY, None)
        - pattern-not: |
            os.environ.get($KEY, None)
        - pattern-not: |
            os.getenv($KEY, "")
        - pattern-not: |
            os.environ.get($KEY, "")
    message: >
      Environment variable lookup with a non-empty hardcoded fallback. If the
      env var is absent (e.g., in a misconfigured deployment), the hardcoded
      value will be used silently. For secrets, use os.getenv(KEY) with no
      default and fail explicitly when the value is missing. Found in
      {{ client.name }} codebase.
    severity: WARNING
    languages:
      - python
    metadata:
      owasp: "A05:2021 - Security Misconfiguration"
      cwe: "CWE-547: Use of Hard-coded, Security-relevant Constants"
      category: security
      confidence: MEDIUM
      client: {{ client.name }}
      rule-group: secrets
