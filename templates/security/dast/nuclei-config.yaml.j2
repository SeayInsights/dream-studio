# Nuclei scanning configuration for {{ target.name }}
# Generated by dream-studio:dast setup
# Target: {{ target.url }}
# Profile: {{ target.scan_profile | default('passive') }}

target: "{{ target.url }}"

# Template tags selected based on scan profile
{% if target.scan_profile == 'full' %}
tags:
  - cve
  - misconfig
  - exposure
  - takeover
  - tech-detect
  - default-login
  - xss
  - sqli
  - ssrf
  - lfi
  - rfi
  - redirect
severity:
  - critical
  - high
  - medium
  - low
{% elif target.scan_profile == 'api-only' %}
tags:
  - cve
  - misconfig
  - exposure
  - api
  - tech-detect
severity:
  - critical
  - high
  - medium
{% elif target.scan_profile == 'auth-only' %}
tags:
  - cve
  - default-login
  - misconfig
  - token
  - auth-bypass
severity:
  - critical
  - high
  - medium
{% else %}
# passive profile — minimal footprint
tags:
  - tech-detect
  - exposure
severity:
  - critical
  - high
{% endif %}

# Rate limiting — conservative by default
rate-limit: 10
bulk-size: 10
concurrency: 5
timeout: 10

# Output
output: "nuclei-output.jsonl"
jsonl: true

{% if target.excluded_paths is defined and target.excluded_paths %}
# Excluded paths
exclude:
{% for path in target.excluded_paths %}
  - "{{ path }}"
{% endfor %}
{% endif %}

{% if target.auth is defined and target.auth.type is defined and target.auth.type != 'none' %}
# Authentication headers
{% if target.auth.type == 'oauth2' %}
header:
  - "Authorization: Bearer ${env:{{ target.auth.token_env }}}"
{% elif target.auth.type == 'api_key' %}
header:
  - "{{ target.auth.header | default('Authorization') }}: ${env:{{ target.auth.token_env }}}"
{% elif target.auth.type == 'basic' %}
header:
  - "Authorization: Basic ${env:{{ target.auth.token_env }}}"
{% endif %}
{% endif %}
