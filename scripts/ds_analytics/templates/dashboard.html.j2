<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>dream-studio Analytics Dashboard</title>
    <!-- Chart.js via CDN — for true offline use, download and embed inline -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: #1a1a2e;
            color: #e0e0e0;
            min-height: 100vh;
            padding: 2rem;
        }

        h1 {
            text-align: center;
            font-size: 1.8rem;
            font-weight: 600;
            color: #e94560;
            margin-bottom: 2rem;
            letter-spacing: 0.02em;
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 1.25rem;
            margin-bottom: 2rem;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
        }

        .card {
            background: #16213e;
            border-radius: 12px;
            padding: 1.5rem;
            border: 1px solid #0f3460;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(233, 69, 96, 0.15);
        }

        .card h3 {
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #8892b0;
            margin-bottom: 0.5rem;
        }

        .card .big {
            font-size: 2.2rem;
            font-weight: 700;
            color: #e94560;
            line-height: 1.2;
        }

        .card .big.stable { color: #4ecca3; }
        .card .big.improving { color: #4ecca3; }
        .card .big.degrading { color: #e94560; }

        .card p:last-child {
            font-size: 0.85rem;
            color: #8892b0;
            margin-top: 0.25rem;
        }

        .charts {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(480px, 1fr));
            gap: 1.25rem;
            max-width: 1200px;
            margin: 0 auto;
        }

        .chart-container {
            background: #16213e;
            border-radius: 12px;
            padding: 1.5rem;
            border: 1px solid #0f3460;
        }

        .chart-container canvas {
            width: 100% !important;
            max-height: 320px;
        }

        .footer {
            text-align: center;
            margin-top: 2rem;
            font-size: 0.75rem;
            color: #53576a;
        }

        @media (max-width: 600px) {
            body { padding: 1rem; }
            .charts { grid-template-columns: 1fr; }
            h1 { font-size: 1.4rem; }
        }
    </style>
</head>
<body>
    <h1>dream-studio Analytics{% if project_name %} — {{ project_name }}{% endif %}</h1>

    <div class="cards">
        <div class="card">
            <h3>Health Trend</h3>
            <p class="big {{ pulse_trend.trend_direction }}">{{ pulse_trend.trend_direction | capitalize }}</p>
            <p>Slope: {{ "%.2f"|format(pulse_trend.trend_slope) }}</p>
        </div>
        <div class="card">
            <h3>Spec Conversion</h3>
            <p class="big">{{ "%.0f"|format(conversion_rate.rate * 100) }}%</p>
            <p>{{ conversion_rate.total - conversion_rate.orphaned }} / {{ conversion_rate.total }} specs</p>
        </div>
        <div class="card">
            <h3>Skills Tracked</h3>
            <p class="big">{{ skill_velocity | length }}</p>
        </div>
        {% if git_metrics %}
        <div class="card">
            <h3>Commits (90d)</h3>
            <p class="big">{{ git_metrics.total_commits_90d }}</p>
            <p>avg {{ git_metrics.avg_commits_per_week }}/week</p>
        </div>
        <div class="card">
            <h3>Branches</h3>
            <p class="big">{{ git_metrics.branch_count }}</p>
        </div>
        {% elif all_git_metrics %}
        <div class="card">
            <h3>Projects</h3>
            <p class="big">{{ all_git_metrics | length }}</p>
        </div>
        <div class="card">
            <h3>Total Commits (90d)</h3>
            <p class="big">{{ all_git_metrics | sum(attribute='total_commits_90d') }}</p>
        </div>
        {% endif %}
        {% if efficiency %}
        <div class="card">
            <h3>Total Cost</h3>
            <p class="big">${{ "%.2f"|format(efficiency.cost_analysis.total_cost_usd) }}</p>
            <p>{{ efficiency.summary.total_sessions }} sessions</p>
        </div>
        <div class="card">
            <h3>Avg Session Duration</h3>
            <p class="big">{{ efficiency.time_to_context.avg_duration_min }}m</p>
            <p>{{ efficiency.time_to_context.sessions_hitting_75pct }} hit 75%</p>
        </div>
        <div class="card">
            <h3>Avg Burn Rate</h3>
            <p class="big">{{ "{:,}".format(efficiency.token_usage.avg_burn_rate_per_min) }}</p>
            <p>tokens/min</p>
        </div>
        {% endif %}
        {% if hook_timing and hook_timing.handlers %}
        <div class="card">
            <h3>Hook Overhead</h3>
            <p class="big">{{ "%.0f"|format(hook_timing.total_overhead_ms) }}ms</p>
            <p>Slowest: {{ hook_timing.slowest_handler }}</p>
        </div>
        {% endif %}
    </div>

    <div class="charts">
        <div class="chart-container">
            <canvas id="pulseTrend"></canvas>
        </div>
        <div class="chart-container">
            <canvas id="skillVelocity"></canvas>
        </div>
        <div class="chart-container">
            <canvas id="conversionRate"></canvas>
        </div>
        <div class="chart-container">
            <canvas id="orphanedSpecs"></canvas>
        </div>
        {% if git_metrics %}
        <div class="chart-container">
            <canvas id="commitVelocity"></canvas>
        </div>
        {% elif all_git_metrics %}
        <div class="chart-container">
            <canvas id="projectCommits"></canvas>
        </div>
        {% endif %}
        {% if efficiency %}
        <div class="chart-container">
            <canvas id="dailyCost"></canvas>
        </div>
        <div class="chart-container">
            <canvas id="modelCost"></canvas>
        </div>
        <div class="chart-container">
            <canvas id="sessionDuration"></canvas>
        </div>
        <div class="chart-container">
            <canvas id="contextPressure"></canvas>
        </div>
        {% endif %}
        {% if hook_timing and hook_timing.handlers %}
        <div class="chart-container">
            <canvas id="hookTiming"></canvas>
        </div>
        {% endif %}
    </div>

    <div class="footer">Generated by dream-studio analytics</div>

    <script>
        const COLORS = {
            red: '#e94560',
            teal: '#4ecca3',
            blue: '#3a86ff',
            orange: '#ff9f43',
            purple: '#a855f7',
            pink: '#ec4899',
            grid: 'rgba(255,255,255,0.06)',
            tick: '#8892b0'
        };

        const defaultScales = {
            x: { ticks: { color: COLORS.tick }, grid: { color: COLORS.grid } },
            y: { ticks: { color: COLORS.tick }, grid: { color: COLORS.grid } }
        };

        const defaultPlugins = {
            legend: { labels: { color: COLORS.tick } }
        };

        /* --- Pulse Trend (line) --- */
        new Chart(document.getElementById('pulseTrend'), {
            type: 'line',
            data: {
                labels: {{ pulse_trend.dates | tojson }},
                datasets: [{
                    label: 'Health Score',
                    data: {{ pulse_trend.scores | tojson }},
                    borderColor: COLORS.teal,
                    backgroundColor: 'rgba(78, 204, 163, 0.1)',
                    fill: true,
                    tension: 0.3,
                    pointRadius: 4,
                    pointBackgroundColor: COLORS.teal
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Pulse Trend', color: '#fff', font: { size: 14 } }
                },
                scales: {
                    ...defaultScales,
                    y: { ...defaultScales.y, min: 0, max: 100 }
                }
            }
        });

        /* --- Skill Velocity (horizontal bar) --- */
        const skillData = {{ skill_velocity | tojson }};
        new Chart(document.getElementById('skillVelocity'), {
            type: 'bar',
            data: {
                labels: skillData.map(s => s.skill_name),
                datasets: [{
                    label: 'Invocations',
                    data: skillData.map(s => s.invocation_count),
                    backgroundColor: COLORS.blue,
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Skill Velocity', color: '#fff', font: { size: 14 } }
                },
                scales: {
                    x: { ...defaultScales.x, beginAtZero: true },
                    y: { ...defaultScales.y }
                }
            }
        });

        /* --- Conversion Rate (doughnut) --- */
        const converted = {{ conversion_rate.total }} - {{ conversion_rate.orphaned }};
        const orphaned = {{ conversion_rate.orphaned }};
        new Chart(document.getElementById('conversionRate'), {
            type: 'doughnut',
            data: {
                labels: ['Converted', 'Orphaned'],
                datasets: [{
                    data: [converted, orphaned],
                    backgroundColor: [COLORS.teal, COLORS.red],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Spec Conversion Rate', color: '#fff', font: { size: 14 } }
                }
            }
        });

        /* --- Orphaned Specs (bar) --- */
        new Chart(document.getElementById('orphanedSpecs'), {
            type: 'bar',
            data: {
                labels: ['Total Specs', 'Orphaned Specs'],
                datasets: [{
                    label: 'Count',
                    data: [{{ conversion_rate.total }}, {{ conversion_rate.orphaned }}],
                    backgroundColor: [COLORS.blue, COLORS.orange],
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Orphaned Specs', color: '#fff', font: { size: 14 } }
                },
                scales: defaultScales
            }
        });
        {% if git_metrics %}
        /* --- Commit Velocity (line) --- */
        new Chart(document.getElementById('commitVelocity'), {
            type: 'line',
            data: {
                labels: {{ git_metrics.weeks_labels | tojson }},
                datasets: [{
                    label: 'Commits',
                    data: {{ git_metrics.commits_per_week | tojson }},
                    borderColor: COLORS.purple,
                    backgroundColor: 'rgba(168, 85, 247, 0.1)',
                    fill: true,
                    tension: 0.3,
                    pointRadius: 4,
                    pointBackgroundColor: COLORS.purple
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Commit Velocity (12 weeks)', color: '#fff', font: { size: 14 } }
                },
                scales: {
                    ...defaultScales,
                    y: { ...defaultScales.y, beginAtZero: true }
                }
            }
        });
        {% endif %}
        {% if all_git_metrics %}
        /* --- Multi-Project Commits (horizontal bar) --- */
        const projectData = {{ all_git_metrics | tojson }};
        const palette = [COLORS.purple, COLORS.blue, COLORS.teal, COLORS.orange, COLORS.pink, COLORS.red];
        new Chart(document.getElementById('projectCommits'), {
            type: 'bar',
            data: {
                labels: projectData.map(p => p.project_name),
                datasets: [{
                    label: 'Commits (90d)',
                    data: projectData.map(p => p.total_commits_90d),
                    backgroundColor: projectData.map((_, i) => palette[i % palette.length]),
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Commits by Project (90 days)', color: '#fff', font: { size: 14 } }
                },
                scales: {
                    x: { ...defaultScales.x, beginAtZero: true },
                    y: { ...defaultScales.y }
                }
            }
        });
        {% endif %}
        {% if efficiency %}
        /* --- Daily Cost Trend (line) --- */
        const dailyCostData = {{ efficiency.cost_analysis.daily_trend | tojson }};
        const dailyCostDates = Object.keys(dailyCostData);
        const dailyCostValues = dailyCostDates.map(d => dailyCostData[d].cost_usd);
        new Chart(document.getElementById('dailyCost'), {
            type: 'line',
            data: {
                labels: dailyCostDates,
                datasets: [{
                    label: 'Cost (USD)',
                    data: dailyCostValues,
                    borderColor: COLORS.orange,
                    backgroundColor: 'rgba(255, 159, 67, 0.1)',
                    fill: true,
                    tension: 0.3,
                    pointRadius: 4,
                    pointBackgroundColor: COLORS.orange
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Daily Cost Trend (USD)', color: '#fff', font: { size: 14 } }
                },
                scales: {
                    ...defaultScales,
                    y: { ...defaultScales.y, beginAtZero: true }
                }
            }
        });

        /* --- Model Cost Breakdown (doughnut) --- */
        const modelCostData = {{ efficiency.cost_analysis.per_model | tojson }};
        const modelCostLabels = Object.keys(modelCostData);
        const modelCostValues = modelCostLabels.map(m => modelCostData[m].cost_usd);
        const costPalette = [COLORS.orange, COLORS.blue, COLORS.teal, COLORS.purple, COLORS.pink, COLORS.red];
        new Chart(document.getElementById('modelCost'), {
            type: 'doughnut',
            data: {
                labels: modelCostLabels,
                datasets: [{
                    data: modelCostValues,
                    backgroundColor: modelCostLabels.map((_, i) => costPalette[i % costPalette.length]),
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Model Cost Breakdown (USD)', color: '#fff', font: { size: 14 } }
                }
            }
        });

        /* --- Session Duration (bar) --- */
        const sessionDurData = {{ efficiency.daily_trends | tojson }};
        const sessionDurDates = Object.keys(sessionDurData);
        const sessionDurValues = sessionDurDates.map(d => sessionDurData[d].total_duration_min);
        new Chart(document.getElementById('sessionDuration'), {
            type: 'bar',
            data: {
                labels: sessionDurDates,
                datasets: [{
                    label: 'Total Duration (min)',
                    data: sessionDurValues,
                    backgroundColor: COLORS.blue,
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Session Duration by Day (min)', color: '#fff', font: { size: 14 } }
                },
                scales: {
                    ...defaultScales,
                    y: { ...defaultScales.y, beginAtZero: true }
                }
            }
        });

        /* --- Context Pressure Distribution (bar) --- */
        const ctxPressure = {{ efficiency.context_pressure | tojson }};
        new Chart(document.getElementById('contextPressure'), {
            type: 'bar',
            data: {
                labels: ['<50%', '50-75%', '75-90%', '>90%'],
                datasets: [{
                    label: 'Sessions',
                    data: [
                        {{ efficiency.summary.total_sessions }} - ctxPressure.sessions_over_50pct,
                        ctxPressure.sessions_over_50pct - ctxPressure.sessions_over_75pct,
                        ctxPressure.sessions_over_75pct - ctxPressure.sessions_over_90pct,
                        ctxPressure.sessions_over_90pct
                    ],
                    backgroundColor: [COLORS.teal, COLORS.blue, COLORS.orange, COLORS.red],
                    borderRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Context Pressure Distribution', color: '#fff', font: { size: 14 } }
                },
                scales: {
                    ...defaultScales,
                    y: { ...defaultScales.y, beginAtZero: true }
                }
            }
        });
        {% endif %}

        {% if hook_timing and hook_timing.handlers %}
        /* --- Hook Timing (horizontal bar) --- */
        const hookData = {{ hook_timing.handlers | tojson }};
        new Chart(document.getElementById('hookTiming'), {
            type: 'bar',
            data: {
                labels: hookData.map(h => h.handler),
                datasets: [{
                    label: 'Avg Duration (ms)',
                    data: hookData.map(h => h.avg_ms),
                    backgroundColor: hookData.map(h =>
                        h.avg_ms > 100 ? COLORS.red :
                        h.avg_ms > 20 ? COLORS.orange : COLORS.teal
                    ),
                    borderRadius: 4
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                plugins: {
                    ...defaultPlugins,
                    title: { display: true, text: 'Hook Handler Performance (avg ms)', color: '#fff', font: { size: 14 } }
                },
                scales: {
                    x: { ...defaultScales.x, beginAtZero: true },
                    y: { ...defaultScales.y }
                }
            }
        });
        {% endif %}
    </script>
</body>
</html>
