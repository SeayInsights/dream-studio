    pattern: "Many elements animate in at exactly the same time with same duration"
    why_harmful: "Visual chaos, hard to follow, creates cognitive overload, reduces sense of intentionality"
    fix: "Stagger animations with 50-100ms delay between elements. Vary durations based on distance/importance. Use sequential motion to guide attention."

  gray_on_color_background:
    id: gray-on-color-background
    category: color
    pattern: "Gray text (#666, #999) placed on colored backgrounds (blue, green, purple)"
    why_harmful: "Fails WCAG contrast, difficult to read, especially on saturated backgrounds"
    fix: "Use white or off-white text on colored backgrounds. Test contrast with WebAIM. For dark text, use darker grays (#333, #444)."

