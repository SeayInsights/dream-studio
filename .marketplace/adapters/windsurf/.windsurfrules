    id: drop-shadows-everywhere
    category: layout
    pattern: "Drop shadow (0 2px 4px rgba) applied to every card, button, and floating element"
    why_harmful: "Visual noise accumulates, reduces emphasis of important shadows, makes UI feel heavy/dated"
    fix: "Reserve shadows for elevated elements only: modals, dropdowns, tooltips. Use 1-2 shadow styles max (subtle + emphasis). Consider alternative depth cues (borders, bg color)."

  low_contrast_gray_text:
    id: low-contrast-gray-text
    category: color
    pattern: "Light gray text (#999, #AAA) on white or light backgrounds that fails WCAG AA standards"
    why_harmful: "Fails accessibility (WCAG AA requires 4.5:1 contrast for normal text), hard to read for people with low vision, fatiguing"
