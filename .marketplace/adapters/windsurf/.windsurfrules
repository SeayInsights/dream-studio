# Interaction & Feedback Standards
# Sources: WCAG 2.1, iOS Human Interface Guidelines, Material Design, NN/g Research

focus_states:
  visibility: required  # Must be visible on all interactive elements
  minimum_outline_width: 2px
  outline_color_contrast: "WCAG AA minimum (4.5:1 for text, 3:1 for graphics)"
  outline_removal_policy: "Never remove outline without replacement visual feedback"
  custom_focus_indicators:
    preferred: "Colored outline (2-4px, brand-aware)"
    acceptable: "Background color change + outline"
    avoid: "Outline-only removal or color inversion without outline"

touch_targets:
  minimum_size: 44x44px  # WCAG AAA minimum
  recommended_size: 48x48px
  spacing_between_targets: 8px  # Minimum safe spacing to avoid mis-taps
  mobile_web_buttons: "48x48px minimum"
  icon_buttons: "44x44px minimum (padding included)"
  link_text_targets: "Expandable touch area via padding; min 44x44px"

form_interaction:
  inline_validation:
    timing: "On blur or after 500ms of inactivity (progressive disclosure)"
    feedback_style: "Color-coded border (red error, green success) + icon + message"
    message_placement: "Below input, within 8px of field"
    message_max_width: "Match input width or less"

  error_messages:
    placement: "Immediately below field (not placeholder, not separate section)"
    color: "Error color (WCAG AA contrast vs. field background)"
    icon: "Optional (exclamation, X, or warning icon)"
    assistance_text: "Helpful, specific, actionable copy"

  label_positioning:
    preferred: "Above input (persistent, not floating)"
    floating_labels: "Acceptable if implemented accessibly (aria-label retained)"
    placeholder_text: "Never as substitute for label; use for hints only"
    required_indicator: "Asterisk (*) + aria-required, visible always"

  disabled_state:
    cursor: "not-allowed (not default)"
    opacity: "60-70% or lower brightness"
    color: "Gray with reduced contrast to indicate unavailability"

loading_states:
  skeleton_screens:
    preferred: true  # Use for content-heavy sections
    placeholder_style: "Neutral gray 20% background, shimmer animation optional"
    timing: "Show immediately on load (no delay)"

  spinners_loaders:
    use_case: "Use only for non-content actions (form submission, data fetch <500ms)"
    avoid_case: "Never for initial page load with content (use skeleton instead)"

  feedback_timing:
