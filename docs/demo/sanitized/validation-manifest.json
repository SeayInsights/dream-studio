{
  "schema": "dream_studio.sanitized_demo_readiness.v1",
  "verdict": "public_demo_ready",
  "demo_mode": "public_sanitized",
  "screenshots_are_synthetic": true,
  "synthetic_data_live_operator_view": false,
  "live_sqlite_mutation_authorized": false,
  "external_project_mutation_authorized": false,
  "push_deploy_authorized": false,
  "private_data_excluded": [
    "private_work_orders",
    "handoffs",
    "local_runtime_paths",
    "raw_telemetry",
    "operator_decisions",
    "career_data",
    "application_data",
    "compensation_strategy",
    "private_external_project_details",
    "sensitive_project_details",
    "secrets_auth_config_values",
    "unsanitized_security_findings"
  ],
  "demo_modes": {
    "observe": [
      "dashboard",
      "projects",
      "contract_atlas",
      "telemetry",
      "evidence",
      "readiness_status",
      "security_status"
    ],
    "assist": [
      "context_packet_generation",
      "manual_adapter_result_import",
      "evidence_capture",
      "task_attribution"
    ],
    "operate": [
      "route_decision",
      "work_order",
      "validation",
      "approval_boundary",
      "safe_continuation"
    ]
  },
  "artifacts": [
    "README.md",
    "5-minute-script.md",
    "15-minute-technical-walkthrough.md",
    "fallback-plan.md",
    "screenshots/observe-mode.png",
    "screenshots/assist-mode.png",
    "screenshots/operate-mode.png"
  ],
  "validation_requirements": [
    "no_absolute_local_paths",
    "no_private_operational_history",
    "no_career_or_application_data",
    "no_secret_like_values",
    "synthetic_screenshots_labeled",
    "fallback_plan_present",
    "observe_assist_operate_covered"
  ],
  "remaining_caveat": "Live operator dashboard demos are private-demo-only until separately reviewed and sanitized."
}
