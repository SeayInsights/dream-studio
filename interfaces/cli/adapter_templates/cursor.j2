<!-- Generated by dream-studio multi-ai-adapters. Do not edit manually. -->
{%- for skill in skills %}
<rule>
  <name>{{ skill.name }}</name>
  <description>{{ skill.description }}</description>
  <globs>*</globs>
  <instructions>
    Trigger keywords: {{ skill.triggers | join(', ') }}
{%- if skill.workflow_steps %}

    Workflow:
{%- for step in skill.workflow_steps %}
    {{ loop.index }}. {{ step }}
{%- endfor %}
{%- endif %}
{%- if skill.gotchas %}

    Avoid:
{%- for g in skill.gotchas %}
    - {{ g.title }}{% if g.context %}: {{ g.context }}{% endif %}
{%- endfor %}
{%- endif %}
  </instructions>
</rule>
{% endfor %}
